{
  "name": "@sequel/foundation",
  "version": "0.2.2",
  "private": true,
  "description": "Shared Sequel Ortho design system, UX conventions, branded deck/document kit, and LLM plumbing — extracted from Project Hub (project-insights) and the Acquisition Hub (Sequel_Ortho).",
  "type": "module",
  "exports": {
    "./brand/tokens.css": "./brand/tokens.css",
    "./brand/theme.css": "./brand/theme.css",
    "./brand/assets/*": "./brand/assets/*",
    "./theme": "./theme/theme.ts",
    "./theme/ThemeToggle": "./theme/ThemeToggle.tsx",
    "./ui": "./ui/index.ts",
    "./llm": "./llm/index.ts",
    "./deck-kit": "./deck-kit/index.ts",
    "./deck-kit/brand-deck": "./deck-kit/brand-deck.ts",
    "./deck-kit/deck-charts": "./deck-kit/deck-charts.ts",
    "./docs-kit/guide-contents": "./docs-kit/guide-contents.mjs",
    "./docs-kit/docx-brand": "./docs-kit/docx-brand.ts",
    "./docs-kit/xlsx-brand": "./docs-kit/xlsx-brand.ts",
    "./scripts/*": "./scripts/*"
  },
  "scripts": {
    "pretest": "scripts/clean-icloud-dups.sh",
    "prebuild": "scripts/clean-icloud-dups.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "scripts/clean-icloud-dups.sh && tsc --noEmit",
    "clean:dups": "scripts/clean-icloud-dups.sh"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.100.0",
    "docx": ">=9",
    "exceljs": ">=4.4.0",
    "jszip": ">=3.10.0",
    "next": ">=15",
    "pptx-automizer": ">=0.8.0",
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "docx": { "optional": true },
    "exceljs": { "optional": true },
    "jszip": { "optional": true },
    "next": { "optional": true },
    "pptx-automizer": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "^16.2.10",
    "pptx-automizer": "^0.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.2",
    "vitest": "^4"
  }
}
